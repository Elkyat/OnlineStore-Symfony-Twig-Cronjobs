{% extends 'base.html.twig' %}

{% block title %}Mi tienda{% endblock %}

{# Llevamos el script al bloque correspondiente #}
{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/main.js') }}"></script>
{% endblock %}

{% block body %}
<div class="max-w-6xl mx-auto px-4 py-8">

    <h1 class="text-3xl font-bold mb-6">Mi tienda</h1>

    <p>
        Estado: <span id="tags">{{ product.status ?? 'Sin estado' }}</span>
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
    {% for product in products %}
        <div 
            onclick="expandGridElement(this)"
    class="product-card bg-white rounded-2x1 shadow-md p-4 hover:shadow-xl transition-all duration-300 cursor-pointer md:col-span-1"
        >
            <img 
                src="{{ product.image ?? 'https://via.placeholder.com/250' }}" 
                class="w-full h-48 object-cover rounded-lg mb-4"
            >

            <h3 class="text-lg font-semibold mb-2 italic">{{ product.name }}</h3>

            <p class="text-gray-600 font-bold text-sm mb-2">{{ product.description }}</p>

            <span class="inline-block bg-gray-200 text-gray-700 text-xs font-bold italic px-3 py-1 rounded-full shadow-sm transform -skew-x-12 select-none">
                {{ product.tag }}
            </span>

            <p class="text-xl font-bold text-green-600">${{ product.price }}</p>
        </div>
    {% endfor %}
</div>

</div>
{% endblock %}