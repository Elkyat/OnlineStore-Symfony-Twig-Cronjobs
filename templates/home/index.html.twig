{% extends 'base.html.twig' %}

{% block title %}Mi tienda{% endblock %}

{% block body %}
<h1>Mi tienda</h1>

<a href="{{ path('product_new') }}">➕ Crear producto</a>

<div class="product-grid">

    {% for product in products %}
        <div class="product">
            <img src="{{ product.image ?? 'https://via.placeholder.com/250' }}">

            <h3>{{ product.name }}</h3>

            <p>{{ product.description }}</p>

            <p>${{ product.price }}</p>

            <div class="actions">
                <a href="{{ path('product_show', {id: product.id}) }}">
                    <button>Ver</button>
                </a>

                <a href="{{ path('product_edit', {id: product.id}) }}">
                    <button>Editar</button>
                </a>

                <form method="post" action="{{ path('product_delete', {id: product.id}) }}" style="display:inline;">
                    <button type="submit">Eliminar</button>
                </form>
            </div>
        </div>
    {% else %}
        <p>No hay productos cargados.</p>
    {% endfor %}

</div>

{% endblock %}